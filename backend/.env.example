# NamRent Backend — Environment Variables
# Copy this file to .env and fill in your values.

# Django
SECRET_KEY=your-very-long-random-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=namrent
DB_USER=namrent
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# CORS — frontend URL(s)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=NamRent <no-reply@namrent.com>
# For production only:
# SENDGRID_API_KEY=SG.xxxx

# File Storage — DigitalOcean Spaces (set USE_S3=True in production)
USE_S3=False
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_BUCKET_NAME=namrent-media
SPACES_ENDPOINT_URL=https://ams3.digitaloceanspaces.com
