# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-in-production
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=namrent
DB_USER=namrent
DB_PASSWORD=changeme
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave as console backend for local dev; switch to SendGrid in production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=NamRent <no-reply@namrent.com>
SERVER_EMAIL=no-reply@namrent.com

# ── File Storage (DigitalOcean Spaces / S3) ───────────────────────────────────
USE_S3=False
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
SPACES_BUCKET_NAME=
SPACES_ENDPOINT_URL=
